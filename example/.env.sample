# =============================================================================
# AICodeReviewer — Environment Variables
# =============================================================================
# 1. Copy this file as .env:  cp .env.sample .env
# 2. Fill in the values below.
# 3. NEVER commit .env to version control.
#
# Generate a random hex secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ---------------------------------------------------------------------------
# Required — LLM
# ---------------------------------------------------------------------------
# API key for your LLM provider.
# Referenced by config.yaml → llm.providers[].api_key_env
AICR_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Required — Gitea / Forgejo
# ---------------------------------------------------------------------------
# Personal access token with repo + issue permissions (OUTBOUND — used by AICR
# to post review comments and read files).
# Referenced by config.yaml → triggers[].token_env
AICR_GITEA_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HMAC-SHA256 secret shared between Gitea webhook and AICR server (INBOUND —
# used to verify that incoming webhook requests are authentic).
# Set this as the "Secret" field when creating the Gitea webhook.
# Referenced by config.yaml → triggers[].webhook_secret_env
AICR_WEBHOOK_SECRET=change_me_to_a_random_hex_string

# ---------------------------------------------------------------------------
# Optional — GitHub
# ---------------------------------------------------------------------------
# AICR_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AICR_GITHUB_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Optional — GitLab
# ---------------------------------------------------------------------------
# AICR_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
# AICR_GITLAB_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Optional — P4 (Perforce)
# ---------------------------------------------------------------------------
# Outbound credentials used by AICR to connect to the P4 server.
# Referenced by config.yaml → triggers[].user_env / password_env
# AICR_P4USER=p4-ci
# AICR_P4PASSWORD=your-p4-password-or-ticket

# ---------------------------------------------------------------------------
# Optional — Server-level API authentication (for /triggers/* only)
# ---------------------------------------------------------------------------
# When server.auth is configured in config.yaml, the P4 trigger script and
# other /triggers/* callers must send X-API-Key or Authorization: Bearer <key>.
# /webhooks/* routes (Gitea, GitHub, GitLab) use HMAC instead — not affected.
# Referenced by config.yaml → server.auth.api_key_env
# AICR_API_KEY=

# Per-workspace API keys (optional override of global key).
# Referenced by config.yaml → workspaces.instances.<id>.auth.api_key_env
# AICR_MY_REPO_API_KEY=
# AICR_WORKSPACE_API_KEY=

# ---------------------------------------------------------------------------
# Optional — Observability dashboard admin
# ---------------------------------------------------------------------------
# Enables /dashboard and /api/admin/* when config.yaml references these envs
# (or when the default admin env names are used by parsed config).
# Prefer password hash in production; value format is sha256:<hex>.
# AICR_ADMIN_USERNAME=admin
# AICR_ADMIN_PASSWORD=
# AICR_ADMIN_PASSWORD_HASH=

# ---------------------------------------------------------------------------
# Optional — Unified storage backends
# ---------------------------------------------------------------------------
# SQLite is the current built-in observability store and defaults to
# /app/data/aicr.sqlite. The following are reserved extension envs for
# future Postgres / Redis / S3-compatible deployments.
# AICR_DATABASE_URL=postgres://user:pass@postgres:5432/aicr
# AICR_REDIS_URL=redis://redis:6379/0
# AICR_S3_ENDPOINT_URL=https://s3.example.com
# AICR_S3_REGION=us-east-1
# AICR_S3_ACCESS_KEY_ID=
# AICR_S3_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Optional — GitHub multi-profile
# ---------------------------------------------------------------------------
# When using multiple GitHub trigger profiles on the same /webhooks/github
# route, each profile needs its own token and webhook secret.
# Tokens used by github_problem_issue must have repository Issues read/write;
# webhook event subscriptions do not grant API permissions.
# AICR_GITHUB_PARTNER_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AICR_GITHUB_PARTNER_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Optional — Feishu problem issue notification
# ---------------------------------------------------------------------------
# Separate Feishu webhook for problem issue lifecycle notifications.
# Referenced by config.yaml → outputs.channels[].webhook_url_env / secret_env
# FEISHU_ISSUE_NOTIFY_WEBHOOK=
# FEISHU_ISSUE_NOTIFY_SECRET=

# ---------------------------------------------------------------------------
# Optional — Feishu (飞书) bot
# ---------------------------------------------------------------------------
# AICR_FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
# AICR_FEISHU_SECRET=your-signing-secret

# ---------------------------------------------------------------------------
# Optional — WeCom (企业微信) bot
# ---------------------------------------------------------------------------
# AICR_WECOM_WEBHOOK=

# ---------------------------------------------------------------------------
# Optional — Server
# ---------------------------------------------------------------------------
# HTTP port (default: 8080)
# AICR_PORT=8080

# Base directory for workspace clones (default: cwd)
# AICR_BASE_DIR=/app

# ---------------------------------------------------------------------------
# Optional — Advanced LLM providers
# ---------------------------------------------------------------------------
# Azure OpenAI
# AICR_AZURE_API_KEY=
# AICR_AZURE_ENDPOINT=https://xxx.openai.azure.com/

# Anthropic
# AICR_ANTHROPIC_API_KEY=

# Google Vertex AI
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# AWS Bedrock
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Ollama (local)
# AICR_OLLAMA_BASE_URL=http://localhost:11434/v1
