{
  "name": "aicodereviewer",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r exec rimraf dist coverage .turbo",
    "dev:cli": "pnpm --filter @aicr/cli dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "markdownlint": "markdownlint-cli2 \"**/*.md\" \"!**/node_modules/**\" \"!**/dist/**\" \"!**/coverage/**\"",
    "test": "vitest run --coverage",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm markdownlint && pnpm build"
  },
  "devDependencies": {
    "@aicr/cli": "workspace:*",
    "@eslint/js": "^9.25.1",
    "@types/node": "^24.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.2.4"
  }
}