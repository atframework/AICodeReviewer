---
// Root landing page: redirects to the user's preferred locale based on
// browser language. With symmetric i18n routing (both /en/ and /zh-cn/
// are prefixed), the root / has no Starlight-generated page. This page
// fills that gap with a fast client-side redirect.
// <https://starlight.astro.build/guides/i18n/#root-locale>
---

<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AICodeReviewer Documentation</title>
    <meta name="description" content="Self-hosted AI code review orchestration service documentation" />
    <meta name="robots" content="noindex" />
    <noscript>
      <meta http-equiv="refresh" content="0;url=/en/" />
    </noscript>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100dvh;
        background: #0d1117;
        color: #e6edf3;
      }
      .card {
        text-align: center;
        max-width: 28rem;
        padding: 2rem;
      }
      h1 { font-size: 1.5rem; font-weight: 600; margin-bottom: 0.75rem; }
      p { color: #8b949e; font-size: 0.9375rem; line-height: 1.5; margin-bottom: 1.5rem; }
      .links { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
      a {
        display: inline-block;
        padding: 0.5rem 1.25rem;
        border: 1px solid #30363d;
        border-radius: 0.375rem;
        color: #58a6ff;
        text-decoration: none;
        font-size: 0.9375rem;
        transition: background 0.15s, border-color 0.15s;
      }
      a:hover { background: #161b22; border-color: #58a6ff; }
    </style>
    <script>
      (() => {
        try {
          const lang = (navigator.language || "").toLowerCase();
          const target = lang.startsWith("zh") ? "/zh-cn/" : "/en/";
          location.replace(target);
        } catch {
          location.href = "/en/";
        }
      })();
    </script>
  </head>
  <body>
    <main class="card">
      <h1>AICodeReviewer Docs</h1>
      <p>Redirecting to your preferred language&hellip;</p>
      <div class="links">
        <a href="/en/">English</a>
        <a href="/zh-cn/">简体中文</a>
      </div>
    </main>
  </body>
</html>
