{
  "name": "@aicr/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('node:fs'); fs.mkdirSync('dist/dashboard',{recursive:true}); fs.copyFileSync('src/dashboard/dashboard.html','dist/dashboard/dashboard.html');\""
  },
  "dependencies": {
    "@aicr/agents": "workspace:*",
    "@aicr/core": "workspace:*",
    "@aicr/llm": "workspace:*",
    "@aicr/mcp-output": "workspace:*",
    "@aicr/outputs": "workspace:*",
    "@aicr/sandbox": "workspace:*",
    "@aicr/store": "workspace:*",
    "@aicr/vcs": "workspace:*",
    "hono": "^4.7.7",
    "zod": "^3.24.4"
  },
  "optionalDependencies": {
    "ioredis": "^5.6.1"
  }
}
